<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>{{.Title}}</title>
<link rel="stylesheet" href="{{cssHref}}">
</head>
<body>
<div class="layout">
{{template "sidebar" .Sidebar}}
<main>
<p class="kicker">aiwf · {{.Kind}}</p>
<h1>{{.Title}}</h1>
<nav class="chip-strip">
<a class="chip" href="#active" id="active">Active</a>
<a class="chip" href="#all" id="all">All</a>
</nav>
{{- if .Entries}}
<table class="kind-index">
<thead><tr><th>Id</th><th>Title</th><th>Status</th>{{if .IncludeArchived}}<th>Location</th>{{end}}</tr></thead>
<tbody>
{{- range .Entries}}
<tr>
<td><a href="{{.FileName}}">{{.ID}}</a></td>
<td>{{.Title}}</td>
<td><span class="status status-{{.Status}}">{{.Status}}</span></td>
{{- if $.IncludeArchived}}
<td>{{if .Archived}}<span class="archived-marker">archived</span>{{else}}active{{end}}</td>
{{- end}}
</tr>
{{- end}}
</tbody>
</table>
{{- else}}
<p>No entries.</p>
{{- end}}
</main>
</div>
</body>
</html>
