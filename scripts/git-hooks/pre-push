#!/bin/sh
# pre-push (kernel pre-push gates): lint boundary (G-0179) +
# secret scan (G-0291).
#
# Blocks a push that would carry unlinted Go changes or leaked
# secrets / contributor paths across the machine boundary.
#
# Lint boundary (G-0179): long-lived branches accumulate
# golangci-lint debt invisibly — CI only lints on push, and
# per-milestone validation as practiced ran `go vet` + `go test`,
# not the full lint set. G-0179's evidence was 9 CI-blocking
# findings spanning three milestone wraps, all invisible until the
# epic branch was finally pushed. This hook runs the same linter CI
# runs, locally, before the push leaves the machine.
#
# Secret scan (G-0291): gitleaks scans the pushed commit range for
# secrets / contributor-path leaks. Relocated here from pre-commit —
# the leak is not exposed until the push, and per-commit scanning
# taxed every commit's latency. The push is the real trust boundary.
#
# Install: `make install-hooks` symlinks this file into
# .git/hooks/pre-push.local — the G45 chain target invoked by
# aiwf's chain-aware pre-push hook before `aiwf check`. Updates to
# this file propagate immediately (the symlink resolves at
# hook-fire time).
#
# Short-circuit (lint only): the Go lint gate fires only when a
# pushed range touches Go surfaces (*.go, go.mod, go.sum,
# .golangci.yml). Planning-tree pushes (gap adds, promotes, archive
# sweeps) pay zero lint. The secret scan is ungated — any pushed
# file can carry a secret — so it scans the pushed range on every
# push.
#
# Scope approximation (lint): when triggered, the linter runs
# against the checked-out working tree, not the pushed commits
# themselves — checking out the pushed sha into a temp worktree per
# push would be disproportionate (KISS). Two consequences, both
# acceptable: a dirty tree can block a push whose commits are clean
# (fix or stash, then push), and a tree-side fix can mask debt
# inside the pushed commits (CI, which lints the pushed sha, remains
# the backstop). The secret scan, by contrast, scans the pushed
# commit range directly, not the tree.
#
# Tolerant by design: a missing tool on PATH is a warning, not a
# block — golangci-lint and gitleaks both self-skip. CI runs both
# independently — golangci-lint (the `go` workflow) and gitleaks (the
# `gitleaks` workflow: full-history scan with .gitleaksignore for
# accepted historical findings) — so this hook is the local
# fast-feedback complement, not the only chokepoint. Escape hatch for
# a deliberate push past either gate: `git push --no-verify`
# (sovereign, visible, human-initiated).
#
# Test overrides: AIWF_PREPUSH_LINT_CMD replaces the lint command
# (default: "golangci-lint run") and AIWF_PREPUSH_GITLEAKS_CMD
# replaces the gitleaks command (default: "gitleaks git
# --config=.gitleaks.toml --no-banner"). The policy tests in
# internal/policies/prepush_lint_hook_test.go use them to pin the
# trigger/skip decision without running the real tools.

set -e

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

lint_cmd="${AIWF_PREPUSH_LINT_CMD:-golangci-lint run}"
gitleaks_cmd="${AIWF_PREPUSH_GITLEAKS_CMD:-gitleaks git --config=.gitleaks.toml --no-banner}"

zero="0000000000000000000000000000000000000000"
needs_lint=0
gitleaks_ranges=""
gitleaks_scan_all=0

# Stdin: one line per ref being pushed,
# "<local-ref> <local-sha> <remote-ref> <remote-sha>".
while read -r local_ref local_sha remote_ref remote_sha; do
    [ -n "$local_sha" ] || continue
    # Deleting a remote ref pushes no content — nothing to scan.
    [ "$local_sha" = "$zero" ] && continue
    if [ "$remote_sha" = "$zero" ]; then
        # New ref on the remote: no prior remote state to diff
        # against. Diff from the merge-base with origin/main when
        # one exists; otherwise be conservative — lint, and scan the
        # full history for secrets.
        if base="$(git merge-base "$local_sha" origin/main 2>/dev/null)"; then
            range="$base..$local_sha"
        else
            needs_lint=1
            gitleaks_scan_all=1
            continue
        fi
    else
        range="$remote_sha..$local_sha"
    fi
    if ! all_changed="$(git diff --name-only "$range" 2>/dev/null)"; then
        # Range not resolvable locally (e.g. remote sha not
        # fetched) — be conservative: lint, and full-history scan.
        needs_lint=1
        gitleaks_scan_all=1
        continue
    fi
    # Secret scan is ungated: collect every non-empty pushed range.
    # (An empty commit has no file diff, so gitleaks — scanning file
    # content — has nothing to read; skipping it is correct, not a gap.)
    [ -n "$all_changed" ] && gitleaks_ranges="$gitleaks_ranges $range"
    # Lint gate is Go-gated: only Go-surface changes trigger it.
    if [ -n "$(git diff --name-only "$range" -- '*.go' go.mod go.sum .golangci.yml 2>/dev/null)" ]; then
        needs_lint=1
    fi
done

# --- Go lint boundary gate (G-0179): Go-surface changes only. ---
if [ "$needs_lint" -eq 1 ]; then
    lint_bin="${lint_cmd%% *}"
    if ! command -v "$lint_bin" >/dev/null 2>&1; then
        echo "pre-push.local: $lint_bin not on PATH — lint boundary gate skipped." >&2
        echo "                CI runs golangci-lint independently. Install:" >&2
        echo "                https://golangci-lint.run/welcome/install/" >&2
    else
        # Scope the lint cache per working tree. golangci-lint's default
        # user-level cache stores raw issues keyed by package content hash
        # but carrying the absolute paths of whichever checkout linted the
        # package; a hit from another worktree replays those paths, and once
        # that worktree is deleted the nolint/filter processors cannot
        # re-read the files, fail open, and leak suppressed findings into
        # this gate — false-blocking the push. A cache under this checkout's
        # own git dir (.git/, or .git/worktrees/<name>/ — removed by `git
        # worktree remove`) makes cross-worktree replay impossible. A
        # pre-set GOLANGCI_LINT_CACHE is respected as an operator override.
        if [ -z "${GOLANGCI_LINT_CACHE:-}" ]; then
            GOLANGCI_LINT_CACHE="$(git rev-parse --absolute-git-dir)/golangci-lint-cache"
            export GOLANGCI_LINT_CACHE
        fi
        # Word-splitting of $lint_cmd is intentional (command + args).
        if ! $lint_cmd >&2; then
            echo "" >&2
            echo "pre-push.local: lint failed — push blocked (G-0179)." >&2
            echo "                Note: lint runs against the checked-out working tree," >&2
            echo "                so uncommitted edits count. Fix the findings, or for a" >&2
            echo "                deliberate unlinted push: git push --no-verify" >&2
            exit 1
        fi
    fi
fi

# --- Secret-scan gate (G-0291): ungated; any pushed file can leak. ---
if [ "$gitleaks_scan_all" -eq 1 ] || [ -n "$gitleaks_ranges" ]; then
    gitleaks_bin="${gitleaks_cmd%% *}"
    if ! command -v "$gitleaks_bin" >/dev/null 2>&1; then
        echo "pre-push.local: $gitleaks_bin not on PATH — local secret-scan skipped." >&2
        echo "                The gitleaks CI workflow still gates this push; for" >&2
        echo "                local fast feedback install gitleaks:" >&2
        echo "                go install github.com/zricethezav/gitleaks/v8@v8.30.1" >&2
    else
        # Word-splitting of $gitleaks_cmd is intentional (command + args).
        gitleaks_ok=1
        if [ "$gitleaks_scan_all" -eq 1 ]; then
            # Conservative fallback: scan the full history.
            $gitleaks_cmd >&2 || gitleaks_ok=0
        else
            # Scan only the pushed commit range(s).
            $gitleaks_cmd --log-opts="${gitleaks_ranges# }" >&2 || gitleaks_ok=0
        fi
        if [ "$gitleaks_ok" -eq 0 ]; then
            echo "" >&2
            echo "pre-push.local: gitleaks reported path-leak / secret findings (G-0291)." >&2
            echo "                These would cross the machine boundary on push. Fix the" >&2
            echo "                offender, allowlist via .gitleaks.toml, or fingerprint-ignore." >&2
            echo "                For a deliberate push: git push --no-verify" >&2
            exit 1
        fi
    fi
fi

exit 0
