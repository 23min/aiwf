{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/validate-agent-isolation.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": ".claude/statusline.sh"
  },
  "enabledPlugins": {
    "wf-rituals@ai-workflow-rituals": true,
    "aiwf-extensions@ai-workflow-rituals": true
  },
  "extraKnownMarketplaces": {
    "ai-workflow-rituals": {
      "source": {
        "source": "github",
        "repo": "23min/ai-workflow-rituals"
      }
    }
  }
}
